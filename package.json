{
  "name": "intervals-icu-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Intervals.icu API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "intervals-icu-mcp": "./dist/mcp/stdio.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp/stdio.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate:from-tp": "tsx scripts/migrate-from-tp.ts",
    "prepare": "husky"
  },
  "keywords": [
    "intervals-icu",
    "cycling",
    "training",
    "api",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Rob West <robertgregorywest@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertgregorywest/intervals-icu-mcp.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.0.0",
    "trainingpeaks-mcp": "file:../trainingpeaks-mcp",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@garmin/fitsdk": "^21.171.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
